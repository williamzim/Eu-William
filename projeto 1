<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>atv</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Helvetica', Arial, sans-serif;
            color: #1d1d1d;
            background-color: white;
        }

        .container {
            width: 90%;
            max-width: 1200px;
            margin: 0 auto;
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 30px 0;
        }

        nav ul {
            display: flex;
            list-style: none;
        }

        nav ul li {
            margin-left: 40px;
        }

        nav ul li a {
            text-decoration: none;
            color: #333;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 2px;
        }

        .topo {
            display: flex;
            align-items: center;
            margin-bottom: 100px;
        }

        .topo-texto {
            width: 40%;
        }

        .topo-texto h1 {
            font-size: 64px;
            color: #bdbdbd;
            font-weight: 300;
            line-height: 1.1;
            text-transform: uppercase;
        }

        .topo-texto h1 span {
            color: #333;
            font-weight: 900;
            display: block;
        }

        .topo-imagem {
            width: 60%;
        }

        .topo-imagem img {
            width: 100%;
            display: block;
        }

        .sobre {
            background-color: #fbfbfb;
            display: flex;
            padding: 60px 30px;
            margin-bottom: 100px;
            gap: 30px;
        }

        .sobre-imagens {
            width: 60%;
            display: flex;
            gap: 20px;
        }

        .img-coluna-1 {
            width: 50%;
        }

        .img-coluna-2 {
            width: 50%;
            padding-top: 40px;
        }

        .sobre-imagens img {
            width: 100%;
            margin-bottom: 20px;
        }

        .sobre-texto {
            width: 40%;
            padding: 20px;
        }

        .sobre-texto h2 {
            font-size: 64px;
            font-weight: 300;
            color: #bdbdbd;
            margin-bottom: 20px;
        }

        .sobre-texto p {
            font-weight: 300;
            line-height: 1.8;
            margin-bottom: 40px;
            color: #333;
        }

        .botao-link {
            display: inline-block;
            padding: 15px 30px;
            background-color: white;
            color: #333;
            text-decoration: none;
            font-size: 12px;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .missao {
            margin-bottom: 80px;
        }

        .missao h2 {
            font-size: 64px;
            font-weight: 300;
            color: #999999;
            margin-bottom: 40px;
        }

        .secundary-page-3-texts {
            display: flex;
            justify-content: flex-start;
            flex-direction: row;
            align-items: center;
            gap: 70px;
            margin-bottom: 120px;
        }

        .secundary-page-3-texts h1 {
            font-size: 10em;
            color: rgb(122, 122, 122);
            font-weight: 900;
        }

        .secundary-page-3-texts p {
            width: 28%;
            word-spacing: 2px;
            line-height: 1.6;
            color: #333;
            font-weight: 300;
        }

        .projetos {
            margin-bottom: 120px;
        }

        .projetos h2 {
            font-size: 64px;
            font-weight: 300;
            color: #bdbdbd;
            margin-bottom: 40px;
        }

        .galeria {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            grid-template-rows: repeat(2, 250px);
            gap: 20px;
            margin-bottom: 30px;
        }

        .item-galeria {
            position: relative;
            overflow: hidden;
            background-color: #f0f0f0;
        }

        .item-galeria img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .item-galeria:nth-child(1) {
            grid-column: span 3;
        }

        .item-galeria:nth-child(2) {
            grid-column: span 3;
        }

        .item-galeria:nth-child(3) {
            grid-column: span 2;
        }

        .item-galeria:nth-child(4) {
            grid-column: span 2;
        }

        .item-galeria:nth-child(5) {
            grid-column: span 2;
        }

        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            color: rgb(255, 255, 255);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 40px;
        }

        .overlay h3 {
            font-size: 40px;
            font-weight: 700;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .botao-preto {
            background-color: #555555;
            color: white;
            padding: 20px 40px;
            text-decoration: none;
            float: right;
            font-size: 12px;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .contato {
            margin-bottom: 100px;
        }

        .contato h2 {
            font-size: 64px;
            font-weight: 300;
            color: #979797;
            margin-bottom: 40px;
        }

        .contato-corpo {
            display: flex;
            gap: 40px;
        }

        form {
            width: 40%;
        }

        form input,
        form textarea {
            width: 100%;
            padding: 15px;
            margin-bottom: 15px;
            background-color: #f3f3f3;
            border: none;
            outline: none;
        }

        .btn-enviar {
            background-color: #555555;
            color: white;
            padding: 20px 45px;
            border: none;
            cursor: pointer;
            letter-spacing: 2px;
            text-transform: uppercase;
            font-size: 12px;
        }

        .contato-img {
            width: 60%;
        }

        .contato-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        footer {
            background-color: #2c2c2c;
            color: white;
            padding: 60px 0 30px;
        }

        .footer-grid {
            display: flex;
            justify-content: space-between;
        }

        .coluna h4 {
            margin-bottom: 25px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .coluna ul {
            list-style: none;
        }

        .coluna ul li {
            margin-bottom: 15px;
            font-size: 14px;
            color: #ccc;
        }

        .redes-sociais a {
            color: white;
            margin-right: 25px;
            font-size: 20px;
        }

        .fim {
            text-align: center;
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid #444;
            color: #777;
            font-size: 12px;
        }
    </style>
</head>

<body>

    <div class="container">
        <nav>
            <div class="logo">
                <img src="Group 11.png" alt="Logo" width="70">
            </div>
            <ul>
                <li><a href="#">Main</a></li>
                <li><a href="#">Gallery</a></li>
                <li><a href="#">Projects</a></li>
                <li><a href="#">Certifications</a></li>
                <li><a href="#">Contacts</a></li>
            </ul>
        </nav>

        <section class="topo">
            <div class="topo-texto">
                <h1>PROJECT <span>LORUM</span></h1>
            </div>
            <div class="topo-imagem">
                <img src="Rectangle 6.png" alt="Main Project Image">
            </div>
        </section>

        <section class="sobre">
            <div class="sobre-imagens">
                <div class="img-coluna-1">
                    <img src="Rectangle 8.png" alt="Work 1">
                    <img src="Rectangle 10.png" alt="Work 2">
                </div>
                <div class="img-coluna-2">
                    <img src="Rectangle 9.png" alt="Work 3">
                </div>
            </div>
            <div class="sobre-texto">
                <h2>About</h2>
                <p>Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the
                    industry's standard dummy text ever since the 1500s.</p>
                <a href="#" class="botao-link">READ MORE &rarr;</a>
            </div>
        </section>

        <section class="missao">
            <h2>Main Focus/Mission Statement</h2>
        </section>

        <div class="secundary-page-3-texts">
            <h1>1</h1>
            <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed efficitur, lectus et facilisis placerat.</p>
            <h1>2</h1>
            <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed efficitur, lectus et facilisis placerat,
                magna mauris porttitor tortor, a auctor est felis ut nisl.</p>
        </div>

        <section class="projetos">
            <h2>Our Projects</h2>
            <div class="galeria">
                <div class="item-galeria">
                    <img src="Rectangle 12.png" alt="Projeto 1">
                    <div class="overlay">
                        <h3>Project Construídos</h3>
                        <a href="#" style="color: white; text-decoration: none; font-size: 12px;">VIEW MORE &rarr;</a>
                    </div>
                </div>
                <div class="item-galeria"><img src="image 15.png" alt="Projeto 2"></div>
                <div class="item-galeria"><img src="image 16.png" alt="Projeto 3"></div>
                <div class="item-galeria"><img src="image 17.png" alt="Projeto 4"></div>
                <div class="item-galeria"><img src="image 18.png" alt="Projeto 5"></div>
            </div>
            <a href="#" class="botao-preto">ALL PROJECTS &rarr;</a>
            <div class="limpar"></div>
        </section>

        <section class="contato">
            <h2>Contact Us</h2>
            <div class="contato-corpo">
                <form>
                    <input type="text" placeholder="Name">
                    <input type="text" placeholder="Phone Number*">
                    <input type="email" placeholder="E-mail*">
                    <input type="text" placeholder="Interested In">
                    <textarea placeholder="Message*"></textarea>
                    <button type="submit" class="btn-enviar">SEND EMAIL &rarr;</button>
                </form>
                <div class="contato-img">
                    <img src="image 12.png" alt="Contact Image">
                </div>
            </div>
        </section>
    </div>

    <footer>
        <div class="container">
            <div class="footer-grid">
                <div class="coluna">
                    <img src="Group 20.png" alt="Logo White" width="100">
                </div>
                <div class="coluna">
                    <h4>Information</h4>
                    <ul>
                        <li>Main</li>
                        <li>Gallery</li>
                        <li>Projects</li>
                        <li>Certifications</li>
                        <li>Contacts</li>
                    </ul>
                </div>
                <div class="coluna">
                    <h4>Contacts</h4>
                    <ul>
                        <li><i class="fa-solid fa-location-dot"></i> 1234 Sample Street, NY 10012</li>
                        <li><i class="fa-solid fa-phone"></i> 512.333.2222</li>
                        <li><i class="fa-solid fa-envelope"></i> sampleemail@gmail.com</li>
                    </ul>
                </div>
                <div class="coluna">
                    <h4>Social Media</h4>
                    <div class="redes-sociais">
                        <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#"><i class="fa-brands fa-twitter"></i></a>
                        <a href="#"><i class="fa-brands fa-linkedin"></i></a>
                        <a href="#"><i class="fa-brands fa-pinterest"></i></a>
                    </div>
                </div>
            </div>
            <div class="fim">
                © 2021 All Rights Reserved
            </div>
        </div>
    </footer>
</body>

</html>
